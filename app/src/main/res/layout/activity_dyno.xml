<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@drawable/bg_racing">

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:layout_above="@+id/navBottom" android:orientation="vertical" android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="DYNO-KW (POWER ESTIMATOR)" android:textColor="@color/racing_yellow" android:textStyle="bold" android:textSize="18sp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="10dp">
            <TextView android:id="@+id/tvLiveG" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="G-Force: 0.00" android:textColor="@color/racing_cyan" android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvLiveKmh" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="0 KM/H" android:textColor="@color/racing_yellow" android:textSize="16sp" android:textStyle="bold" android:gravity="end"/>
        </LinearLayout>

        <com.example.tukuwededed.DynoView
            android:id="@+id/dynoGraph"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginTop="15dp"
            android:background="#1AFFFFFF"/>

        <TextView android:id="@+id/tvMaxPower" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="MAX ESTIMATED POWER: 0 KW" android:textColor="@color/racing_green" android:textSize="20sp" android:textStyle="bold" android:gravity="center" android:layout_marginTop="15dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="15dp">
            <Button android:id="@+id/btnStartDyno" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:text="START RUN" android:backgroundTint="@color/racing_green" android:textColor="#000" android:layout_marginEnd="5dp"/>
            <Button android:id="@+id/btnStopDyno" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:text="STOP" android:backgroundTint="@color/racing_red" android:textColor="#FFF" android:layout_marginStart="5dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp">
            <Button android:id="@+id/btnSaveDyno" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:text="SAVE" android:backgroundTint="@color/card_surface" android:textColor="@color/text_white" android:layout_marginEnd="5dp"/>
            <Button android:id="@+id/btnHistoryDyno" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:text="HISTORY" android:backgroundTint="@color/card_surface" android:textColor="@color/text_white" android:layout_marginStart="5dp"/>
        </LinearLayout>

    </LinearLayout>

    <LinearLayout android:id="@+id/navBottom" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" android:background="#CC020617" android:padding="10dp">
        <Button android:id="@+id/btnBack" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="BACK" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/text_gray"/>
        <Button android:id="@+id/btnHome" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="HOME PAGE" android:backgroundTint="@color/racing_yellow" android:textColor="#000" android:textStyle="bold"/>
    </LinearLayout>
</RelativeLayout>