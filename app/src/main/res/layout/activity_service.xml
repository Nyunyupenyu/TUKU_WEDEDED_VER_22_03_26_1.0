<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@drawable/bg_racing" android:padding="16dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="MAINTENANCE TRACKER" android:textColor="@color/racing_yellow" android:textStyle="bold" android:layout_marginBottom="15dp"/>

        <EditText android:id="@+id/etLastOli" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="KM Ganti Oli Terakhir" android:inputType="number" android:textColor="#FFF" android:textColorHint="@color/text_gray" android:backgroundTint="@color/text_gray"/>
        <EditText android:id="@+id/etDateOli" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Tanggal Ganti Oli (dd/mm/yyyy)" android:textColor="#FFF" android:textColorHint="@color/text_gray" android:backgroundTint="@color/text_gray"/>
        <TextView android:id="@+id/tvEstimasiOli" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Estimasi: Ganti pada +3000km atau 3 bulan" android:textColor="@color/racing_cyan" android:layout_marginBottom="5dp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="*Lakukan pergantian oli rutin setiap maksimal 3000km atau 3 bulan sekali" android:textColor="@color/text_gray" android:textSize="10sp" android:layout_marginBottom="15dp"/>

        <EditText android:id="@+id/etLastBusi" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Tanggal Ganti Busi (dd/mm/yyyy)" android:textColor="#FFF" android:textColorHint="@color/text_gray" android:backgroundTint="@color/text_gray"/>
        <TextView android:id="@+id/tvEstimasiBusi" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Estimasi Ganti Busi: +6 Bulan" android:textColor="@color/racing_cyan" android:layout_marginBottom="10dp"/>

        <EditText android:id="@+id/etLastFilter" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Tanggal Ganti Filter Oli (dd/mm/yyyy)" android:textColor="#FFF" android:textColorHint="@color/text_gray" android:backgroundTint="@color/text_gray"/>
        <TextView android:id="@+id/tvEstimasiFilter" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Estimasi Ganti Filter: +6 Bulan" android:textColor="@color/racing_cyan" android:layout_marginBottom="10dp"/>

        <EditText android:id="@+id/etLastCleaner" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Tanggal Injector Cleaner (dd/mm/yyyy)" android:textColor="#FFF" android:textColorHint="@color/text_gray" android:backgroundTint="@color/text_gray"/>
        <TextView android:id="@+id/tvEstimasiCleaner" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Estimasi Cleaner: +6 Bulan" android:textColor="@color/racing_cyan" android:layout_marginBottom="15dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btnSave" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="SAVE LOG" android:backgroundTint="@color/racing_green" android:textColor="#000" android:layout_marginEnd="5dp"/>
            <Button android:id="@+id/btnHistory" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="HISTORY" android:backgroundTint="@color/card_surface" android:textColor="@color/text_white" android:layout_marginStart="5dp"/>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Fitur ini sangat berguna untuk Anda yang sering lupa jadwal servis berkala kendaraan. Sistem akan memberikan estimasi waktu dan jarak tempuh optimal untuk melakukan pemeliharaan rutin guna menjaga performa mesin tetap prima."
            android:textColor="@color/text_gray" android:textSize="11sp" android:layout_marginTop="30dp" android:gravity="center" android:lineSpacingExtra="2dp"/>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:layout_marginTop="10dp" android:gravity="center" android:orientation="horizontal">
            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@mipmap/ic_launcher" android:alpha="0.6"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" dev by penyu" android:textColor="@color/text_gray" android:textSize="10sp" android:alpha="0.6"/>
        </LinearLayout>

        <Button android:id="@+id/btnBack" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="KEMBALI" android:backgroundTint="@color/racing_yellow" android:textColor="#000" android:layout_marginTop="20dp"/>
    </LinearLayout>
</ScrollView>