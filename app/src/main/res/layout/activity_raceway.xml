<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@drawable/bg_racing">

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:layout_above="@+id/navBottom" android:orientation="vertical" android:padding="16dp">

        <TextView android:id="@+id/tvSpeed" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="0" android:textColor="@color/racing_yellow" android:textSize="130sp" android:textStyle="bold" android:gravity="center" android:layout_marginTop="20dp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="KM/H" android:textColor="@color/text_gray" android:gravity="center" android:layout_marginTop="-20dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="20dp">
            <TextView android:id="@+id/tvDistance" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="0 m" android:textColor="@color/text_white" android:textSize="18sp" android:gravity="center"/>
            <TextView android:id="@+id/tvAccuracy" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="GPS Acc: --" android:textColor="@color/text_gray" android:textSize="14sp" android:gravity="center"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp">
            <Button android:id="@+id/btnStart" android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1" android:text="START" android:backgroundTint="@color/racing_green" android:textColor="#000" android:layout_marginEnd="5dp"/>
            <Button android:id="@+id/btnStop" android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1" android:text="STOP" android:backgroundTint="@color/racing_red" android:textColor="#FFF" android:layout_marginStart="5dp"/>
        </LinearLayout>

        <Button android:id="@+id/btnHistory" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="VIEW RACE HISTORY" android:backgroundTint="@color/card_surface" android:textColor="@color/text_white" android:layout_marginTop="10dp"/>

        <TextView android:id="@+id/tvLog" android:layout_width="match_parent" android:layout_height="150dp"
            android:layout_marginTop="10dp" android:background="#111" android:padding="10dp" android:textColor="@color/racing_green" android:fontFamily="monospace" android:text="> Logger Ready..."/>

        <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Instrumen performa digital untuk mencatat metrik akselerasi secara presisi. Fitur ini secara otomatis merekam kecepatan (km/h), jarak, waktu tempuh, dan top speed. Dilengkapi dengan fitur Auto-Start (saat &gt;5km/h) dan sistem Checkpoint otomatis pada jarak 100m, 200m, 500m, dan 1km untuk analisis data teknis yang lebih mendalam."
                    android:textColor="@color/text_gray" android:textSize="11sp" android:layout_marginTop="20dp" android:gravity="center" android:lineSpacingExtra="2dp"/>

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:layout_marginTop="20dp" android:gravity="center" android:orientation="horizontal">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@mipmap/ic_launcher" android:alpha="0.6"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" dev by penyu" android:textColor="@color/text_gray" android:textSize="10sp" android:alpha="0.6"/>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <LinearLayout android:id="@+id/navBottom" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" android:background="#CC020617" android:padding="10dp">
        <Button android:id="@+id/btnBack" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="BACK" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/text_gray"/>
        <Button android:id="@+id/btnHome" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="HOME PAGE" android:backgroundTint="@color/racing_yellow" android:textColor="#000" android:textStyle="bold"/>
    </LinearLayout>
</RelativeLayout>